# Liza Virtual Companion — Environment Variables
#
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
#
# All variables are optional — the app degrades gracefully when keys are missing.

# Google Gemini API key (FREE)
# Get yours at: https://aistudio.google.com/apikey
# Powers: text chat, voice, language learning, and interview AI
GEMINI_API_KEY=your_gemini_api_key_here

# Pollinations.ai API key (FREE)
# Get yours at: https://enter.pollinations.ai
# Powers: AI avatar image generation (FLUX model)
# Leave blank to use the free public endpoint (no key required)
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# Supabase (optional — enables cloud backend, auth, and persistence)
# Get yours at: https://supabase.com
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
